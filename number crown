 void pattern12(int n){
    for(int i=1;i<=n;i++)
    {
        //num
        for(int j=1;j<=i;j++)
        cout<<j<<" ";
        //space
        for(int j=1;j<=2*(n-i);j++)
        cout<<"  "; //double space
        //num
        for(int j=i;j>0;j--)
        cout<<j<<" ";
        cout<<endl;
    }
 } 
  int main(){
    int t,i,n,r,c;
    cin>>t;
    for(i=0;i<=t;i++)
    {
        cin>>n;
        pattern12(n);
        cout<<endl;
    }
} 
