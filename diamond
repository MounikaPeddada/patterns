#include<iostream>
using namespace std;
void pattern9(int n) {
        for(int i=1;i<=n;i++)
        {
            for(int j=n-i;j>0;j--)
            cout<<" ";
            for(int j=1;j<=2*i-1;j++)
            cout<<"*";
            cout<<endl;
        }
        for(int i=0;i<n;i++)
        {
            for(int j=1;j<=i;j++)
            cout<<" ";
            for(int j=1;j<=2*n-(2*i+1);j++)
            cout<<"*";
            cout<<endl;
        }
    }  
int main(){
    int t,i,n,r,c;
    cin>>t;
    for(i=0;i<=t;i++)
    {
        cin>>n;
        pattern9(n);
        cout<<endl;
    }
} 
