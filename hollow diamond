
#include<stdio.h>
int main()
{
    int n,i,j;
    printf("enter n value");
    scanf("%d",&n);
    for(i=1;i<=n;i++)
    {
        for(j=n-i;j>0;j--)
        {
            printf(" ");
        }
        for(j=1;j<=2*i-1;j++)
        {
            if(j==1 || j==2*i-1)
            printf("*");
            else
            printf(" ");
        }
        printf("\n");
    }
    
    for(i=1;i<=n;i++)
    {
        for(j=1;j<=i;j++)
        {
            printf(" ");
        }

        for(j=n-i;j>0;j--)
        {
            if(j==n-i || j==1)
            printf("* ");
            else
            printf("  ");
        }

        printf("\n");
   
    }
    return 0;
}
