void pattern16(int n)
{
    for(int i=0;i<n;i++)
    {
        for(char j='A';j<='A'+i;j++)
        {
            char alpha='A'+i;
            cout<<alpha<<" ";
        }
        
        cout<<endl;
    }
}
int main(){
    int t,i,n,r,c;
    cin>>t;
    for(i=0;i<=t;i++)
    {
        cin>>n;
        pattern16(n);
        cout<<endl;
    }
}
