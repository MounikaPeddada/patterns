#include<stdio.h>
int main()
{
    int r,i,j;
    printf("enter r value");
    scanf("%d",&r);
    for(i=-r;i<=r;i++)
    {
        for(j=-r;j<=r;j++)
        {
            if((1.5*(i*i)+(j*j))<=1.5*r*r) //multiply i with suitable num depending on the grid size
            printf("* ");
            else
            printf("  ");
        }
        printf("\n");
    }
}
