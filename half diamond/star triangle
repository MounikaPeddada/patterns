    void pattern10(int n) {
        for(int i=0;i<n;i++)
        {
            for(int j=0;j<=i;j++)
            cout<<"*";
            cout<<endl;
        }
        
         for(int i=1;i<n;i++)
        {
            for(int j=n-i;j>0;j--)
            cout<<"*";
            cout<<endl;
        }
    }

    int main(){
    int t,i,n,r,c;
    cin>>t;
    for(i=0;i<=t;i++)
    {
        cin>>n;
        pattern10(n);
        cout<<endl;
    }
} 
