void concentric_rect(int n){
    for(int i=0;i<2*n-1;i++)
    {
        for(int j=0;j<2*n-1;j++)
        {
            int top=i;
            int left=j;
            int bottom=2*(n-1)-i;
            int right = 2*(n-1)-j;
            int val=n-min(min(top,bottom),min(left,right));
            cout<<val<<" ";
        }
        cout<<endl;
    }
}
int main(){
    int t,i,n,r,c;
    cin>>t;
    for(i=0;i<=t;i++)
    {
        cin>>n;
        concentric_rect(n);
        cout<<endl;
    }

} 
