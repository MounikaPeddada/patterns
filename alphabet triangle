void pattern14(int n)
{
    for(int i=0;i<n;i++)
    {
        for(char j='A';j<='A'+i;j++)
        {
            cout<<j<<" ";
        }
        
        cout<<endl;
    }
}
int main(){
    int t,i,n,r,c;
    cin>>t;
    for(i=0;i<=t;i++)
    {
        cin>>n;
        pattern14(n);
        cout<<endl;
    }
} 
